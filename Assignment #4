        operationalSurcharge = 25.00;
    }

    double grossTotal = roomsReserved * nightsStayed * baseRatePerNight;
    double groupDiscountAmount = grossTotal * groupDiscountPercentage;
    double intermediateSubtotal = grossTotal - groupDiscountAmount;
    double durationDiscountAmount = 0.0;

    if (qualifiesForDurationDiscount) {
        durationDiscountAmount = intermediateSubtotal * Duration_discount_Rate;
    }

    double totalDiscountAmount = groupDiscountAmount + durationDiscountAmount;
