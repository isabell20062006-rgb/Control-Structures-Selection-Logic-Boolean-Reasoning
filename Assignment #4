    // ==========================================================
    // Section 3: Operator precedence reference
    // ==========================================================
    /*
    Precedence      Operator(s)     Category        Associativity
    ---------------------------------------------------------------
    1 (highest)     !               Logical NOT     Right to Left
    2               *, /, %         Multiplicative  Left to Right
    3               +, -            Additive        Left to Right
    4               <, <=, >, >=    Relational      Left to Right
    5               ==, !=          Equality        Left to Right
    6               &&              Logical AND     Left to Right
    7 (lowest)      ||              Logic OR        Left to Right

    Expression: !(roomsReserved > 0) || (baseRatePerNight >= 50.0 && roomsReserved != nightsStayed)

    Sample value chosen:
    - roomsReserved = 6
    - baseRatePerNight = 120.0
    - nightsStayed= 4

    Step by step evaluation process:
    1. Parenthessis priority. Inside left: (roomsReserved > 0) -> (6 > 0) -> true
    Expression :!(true) || (baseRatePerNight >= 50.0 && roomsReserved !=nightStayed)
    2. Evaluate Precedence 1 (Logical NOT): !(true) -> false
    Expression: false || (baseRatePerNight >= 50.0 && roomsReserved !=nightStayed)
    3. Evaluate Precedence 4 (Relational) inside right block: 120.0 >= 50.0) -> true
    Expression: false || (true && roomsReserved != nightsStayed)
    4. Evaluate Precedence 5 (Equality) inside right block: (6 != 4) -> true
    Expression: false || (true && true)
    5. Evaluate Precedence 6 (logical AND): (true && true) -> true
    Expression: false || true
    6. Evaluate Precedence 7 (Logic OR): false || true -> true
    
    Final Result: True
    */


    // =================================================================
    // Section 4/6: core logic and relations/logical operator showcase
    // =================================================================

    double groupDiscountPercentage = 0.0;
    int discountTierInteger = 0;
    bool qualifiesForDurationDiscount = false;

    if (roomsReserved >= Group_Tier_3_Limit) {
        groupDiscountPercentage = Group_Tier_3_Discount;
        discountTierInteger = 3;
    }
    else if (roomsReserved >= Group_Tier_2_Limit) {
        groupDiscountPercentage = Group_Tier_2_Discount;
        discountTierInteger = 2;
    }
    else if (roomsReserved >= Group_Tier_1_Limit) {
        groupDiscountPercentage = Group_Tier_1_Discount;
        discountTierInteger = 1;
    }
    else {
        groupDiscountPercentage = 0.0;
        discountTierInteger = 0;
    }

    if (nightsStayed <= 0 || nightsStayed > duration_Treshold) {
        qualifiesForDurationDiscount = true;
    }
    else if (nightsStayed >= duration_Treshold) {
        qualifiesForDurationDiscount = true;
    }

    double operationalSurcharge = 0.0;
    bool balanceThresholdMet = (roomsReserved !=  nightsStayed);
